    54 000000F0 0000                <1> 	dw 0x0
    55 000000F2 00                  <1> 	db 0x0
    56 000000F3 92                  <1> 	db 10010010b
    57 000000F4 CF                  <1> 	db 11001111b
    58 000000F5 00                  <1> 	db 0x0
    59                              <1> 
    60                              <1> gdt_end: ; just for size calculations
    61                              <1> 
