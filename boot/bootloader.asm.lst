    47 000000EC CF                  <1> 	db 11001111b
    48 000000ED 00                  <1> 	db 0x0
    49                              <1> 
    50                              <1> ; GDT for data segment. base and length identical to code segment
    51                              <1> ; some flags changed, again, refer to os-dev.pdf
    52                              <1> gdt_data:
